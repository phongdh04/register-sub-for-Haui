# ============================================================
# EduPort Go Queue Service - Biến Môi Trường
# Copy file này thành .env và điều chỉnh cho phù hợp môi trường
# ============================================================

# Fiber HTTP Server
SERVER_PORT=3000

# Redis (khớp với docker-compose.yml)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=eduport_redis
REDIS_DB=0

# Kafka (khớp với docker-compose.yml)
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=eduport.dang-ky-hoc-phan

# PostgreSQL DSN (dùng cho các query bổ sung nếu cần)
DATABASE_DSN=host=localhost user=eduport_user password=eduport_password dbname=eduport_db port=5432 sslmode=disable TimeZone=Asia/Ho_Chi_Minh
